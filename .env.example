# ─── Database ─────────────────────────────────────────────────────────
# Postgres connection string. Get a free one at https://neon.tech
# Example: postgresql://user:pass@ep-foo-bar-123.eu-central-1.aws.neon.tech/itokent?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/itokent?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────
# Generate a fresh secret with:  openssl rand -base64 32
AUTH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_COMMUNITY_NAME="İtokent Urla"
NEXT_PUBLIC_DEFAULT_LOCALE="tr"

# ─── Email (optional) ─────────────────────────────────────────────────
# Resend API key — free tier: 100 emails/day, 3000/month.
# Sign up at https://resend.com and paste your API key below.
# If unset, the app still works — bookings just won't send confirmation emails.
RESEND_API_KEY=""

# Sender address. Until you've verified a custom domain in Resend, leave this
# empty to fall back to "İtokent Urla <onboarding@resend.dev>" (Resend's shared
# sandbox sender). Once your domain is verified, set this to e.g.:
#   "İtokent Urla <noreply@itokent.tr>"
EMAIL_FROM=""
