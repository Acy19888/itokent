// Villa Community - Prisma Schema
// Modell für ein privates Reservierungs- und Verwaltungssystem

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Role ──────────────────────────────────────────────────────
// Role is kept as a String for forward-compat with SQLite dev databases.
// Allowed values: "RESIDENT" | "ADMIN" | "RESTAURANT_STAFF"
// (enforced at the application layer via the `Role` type in src/lib/auth.config.ts).

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  phone          String?
  passwordHash   String
  role           String   @default("RESIDENT")
  locale         String   @default("tr")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // A resident belongs to a villa. Staff / admins have no villa.
  villaId        String?
  villa          Villa?   @relation(fields: [villaId], references: [id])

  tennisBookings       TennisBooking[]
  partyBookings        PartyHouseBooking[]
  restaurantRes        RestaurantReservation[]
  guests               Guest[]
  maintenanceTickets   MaintenanceTicket[]
  eventsCreated        Event[]          @relation("EventCreator")
  eventRsvps           EventAttendee[]
  announcementsCreated Announcement[]   @relation("AnnouncementAuthor")
}

// ─── Villa ────────────────────────────────────────────────────────────

model Villa {
  id        String   @id @default(cuid())
  number    Int      @unique       // Villa number 1–250
  block     String?                // optional block/section
  createdAt DateTime @default(now())
  residents User[]
}

// ─── Tennis Courts ────────────────────────────────────────────────────

model TennisCourt {
  id        String   @id @default(cuid())
  name      String                 // e.g. "Court 1", "Court 2"
  active    Boolean  @default(true)
  bookings  TennisBooking[]
}

model TennisBooking {
  id           String      @id @default(cuid())
  courtId      String
  court        TennisCourt @relation(fields: [courtId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  date         DateTime                  // date of booking (00:00 local)
  startHour    Int                       // 9..19 (slot from startHour → startHour+1)
  status       String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt    DateTime @default(now())

  @@unique([courtId, date, startHour], name: "unique_slot")
  @@index([userId])
  @@index([date])
}

// ─── Party House ──────────────────────────────────────────────────────

model PartyHouseBooking {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime                  // day of event
  occasion   String                    // e.g. "Birthday party"
  guestCount Int
  notes      String?
  status     String   @default("PENDING")  // PENDING, APPROVED, REJECTED, CANCELLED
  // Admin can set a rental fee when approving.  Minor units (kuruş).
  feeAmount  Int?
  feeCurrency String? @default("TRY")
  paid       Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())

  @@unique([date], name: "one_party_per_day")
  @@index([userId])
}

// ─── Restaurant ───────────────────────────────────────────────────────

// Configurable physical tables. Restaurant staff edits this catalog
// (count, seats, position on floor plan) from /restaurant-app/layout.
// Position is in a fixed 1000×600 SVG coordinate system; the floor-plan
// component scales to whatever container it lives in.
model RestaurantTable {
  id        String   @id @default(cuid())
  number    Int      @unique     // staff-facing label, also used in old reservations
  seats     Int      @default(4) // 1..12
  x         Int      @default(500)
  y         Int      @default(300)
  shape     String   @default("ROUND") // ROUND | SQUARE
  active    Boolean  @default(true)    // soft-delete: keeps old reservations valid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantReservation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime                  // full datetime of reservation
  tableNumber Int      @default(1)      // FK-by-value to RestaurantTable.number
  partySize   Int                       // 1..table.seats
  notes       String?
  checkedIn   Boolean  @default(false)
  status      String   @default("CONFIRMED")  // CONFIRMED, CANCELLED, NO_SHOW
  createdAt   DateTime @default(now())

  // One table can only be reserved by one party per exact time slot.
  // Cancelled reservations still occupy the unique key (we don't re-use
  // a cancelled row); the action flips `status` instead of deleting.
  @@unique([date, tableNumber], name: "table_slot")
  @@index([date])
  @@index([userId])
}

// ─── Events ───────────────────────────────────────────────────────────

model Event {
  id          String   @id @default(cuid())
  titleTr     String
  titleEn     String
  descTr      String
  descEn      String
  location    String
  startsAt    DateTime
  endsAt      DateTime
  imageUrl    String?
  // Optional attendance fee in MINOR UNITS (kuruş for TRY, cents for USD).
  // Using an integer avoids float rounding errors on money. null = free.
  feeAmount   Int?
  feeCurrency String?  @default("TRY")
  createdById String
  createdBy   User     @relation("EventCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  attendees   EventAttendee[]
}

// One row per (event, user) RSVP. A user can toggle attendance on/off;
// we delete the row rather than tracking a status field to keep the
// attendee count query trivially `count()`.
model EventAttendee {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // If the event has a fee, record whether this attendee has paid.
  // For free events this stays false and is ignored.
  paid      Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())

  @@unique([eventId, userId], name: "one_rsvp_per_user_per_event")
  @@index([eventId])
  @@index([userId])
}

// ─── Guests (security / gate) ─────────────────────────────────────────

model Guest {
  id         String   @id @default(cuid())
  hostId     String
  host       User     @relation(fields: [hostId], references: [id])
  name       String
  plate      String?
  arrivesAt  DateTime
  purpose    String?
  checkedIn  Boolean  @default(false)
  checkedInAt DateTime?
  createdAt  DateTime @default(now())

  @@index([arrivesAt])
}

// ─── Announcements / News Feed ────────────────────────────────────────

model Announcement {
  id          String   @id @default(cuid())
  titleTr     String
  titleEn     String
  bodyTr      String
  bodyEn      String
  priority    String   @default("NORMAL")  // NORMAL, HIGH, URGENT
  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  publishedAt DateTime @default(now())
}

// ─── Email verification (self-serve registration) ────────────────────
// A row is created when someone starts registering. Until they confirm
// the 6-digit code, we DON'T have a User row — only this staged record.
// After `confirm`, we create the User + delete the row in the same
// transaction. Unconfirmed rows expire and get garbage-collected
// (`expiresAt` is enforced at the application layer when we look them
// up — any row with expiresAt < now() is treated as missing).
model EmailVerification {
  id           String   @id @default(cuid())
  email        String
  code         String                     // 6-digit numeric, hashed with bcrypt
  // Staged registration payload — NOT a user row yet. We store enough
  // to re-create the user once the code is confirmed. Password is already
  // hashed at this point (done server-side before insert).
  firstName    String
  lastName     String
  phone        String
  villaNumber  Int
  passwordHash String
  attempts     Int      @default(0)       // guard against brute-force code guessing
  expiresAt    DateTime                    // now() + 15m
  createdAt    DateTime @default(now())

  @@index([email])
}

// ─── Maintenance Tickets ──────────────────────────────────────────────

model MaintenanceTicket {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  category   String                    // ELECTRIC, PLUMBING, GARDEN, POOL, OTHER
  title      String
  description String
  status     String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority   String   @default("NORMAL") // LOW, NORMAL, HIGH
  // Optional fee — when admin/staff invoices the resident for the work.
  // Minor units (kuruş for TRY). null = free / not invoiced yet.
  feeAmount   Int?
  feeCurrency String?  @default("TRY")
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resolvedAt DateTime?

  @@index([status])
  @@index([userId])
}
